# Generate with: python -c "import bcrypt; print(bcrypt.hashpw('yourpassword'.encode(), bcrypt.gensalt()).decode())"
ADMIN_PASSWORD_HASH=
JWT_SECRET=

DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/dbname

# GitHub Models — embeddings (PAT with models scope)
GITHUB_MODELS_API_KEY=
GITHUB_MODELS_ENDPOINT=https://models.inference.ai.azure.com

# GitHub REST API — live repo data tool (PAT with public_repo scope)
GITHUB_TOKEN=
GITHUB_USERNAME=

# Cal.com — meeting booking (cal.com/settings/developer/api-keys)
CAL_API_KEY=
CAL_EVENT_TYPE_ID=6147823

# Vapi — shared secret, must match the assistant's server secret in the Vapi dashboard
VAPI_SERVER_SECRET=

# Cloudinary — resume PDF storage
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

MAX_UPLOAD_SIZE_MB=10
IS_PROD=true
LOG_LEVEL=INFO
ALLOWED_ORIGINS=*
